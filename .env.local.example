# Neon PostgreSQL — copie a connection string do painel Neon
# (Dashboard → seu projeto → Connection Details → Connection string)
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# Gate de senha (ver seção "Autenticação" do README)
APP_PASSWORD=defina-uma-senha
AUTH_SECRET=gere-com: openssl rand -hex 32
